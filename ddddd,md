# remove blank between chinese character
def replace_blank(text: str):
    out_str = []
    n = len(text)

    for i, c in enumerate(text):
        if c != " ":
            out_str.append(c)
            continue

        # only keep space when it is between two non-space ASCII chars
        if i > 0 and i < n - 1:
            prev_c = text[i - 1]
            next_c = text[i + 1]
            if (prev_c.isascii() and prev_c != " " and
                    next_c.isascii() and next_c != " "):
                out_str.append(c)

    return "".join(out_str)
